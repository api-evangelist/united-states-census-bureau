            "params": [
              {
                "name": "year",
                "value": "",
                "type": "path",
                "description": "Vintage year for the estimates"
              },
              {
                "name": "get",
                "value": "",
                "type": "query",
                "description": "Variable names (e.g., NAME,POP,DATE_DESC for name, population, and date description)"
              },
              {
                "name": "for",
                "value": "",
                "type": "query",
