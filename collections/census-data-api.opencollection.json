                "description": "Census year (2020 or 2010)"
              },
              {
                "name": "get",
                "value": "",
                "type": "query",
                "description": "Variable names (e.g., P1_001N for total population)"
              },
              {
                "name": "for",
                "value": "",
                "type": "query",
                "description": "Geographic level and FIPS filter"
